<script>
    var countDownDate = new Date("<?php echo $release_date; ?>").getTime();
    var x = setInterval(function() {
        var now = new Date().getTime();
        var distance = countDownDate - now;
        var d = Math.floor(distance / (1000 * 60 * 60 * 24));
        var h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        var m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        var s = Math.floor((distance % (1000 * 60)) / 1000);
        document.getElementById("timer").innerHTML = "🌙 ইদ রিলিজ: " + d + "d " + h + "h " + m + "m " + s + "s ";
        if (distance < 0) { clearInterval(x); document.getElementById("timer").innerHTML = "🚀 MOVIE IS LIVE!"; }
    }, 1000);
</script>
</body>
</html>
